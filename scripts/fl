#!/usr/bin/env bash
# Thin wrapper so fastlane runs on Homebrew Ruby 3.3 (system Ruby 2.6 is too old)
# with the right locale, from the mobile-app project dir.
#
#   scripts/fl bump version:1.1.5
#   scripts/fl ios release
#   scripts/fl android release
set -euo pipefail
cd "$(dirname "$0")/../mobile-app"
export PATH="/opt/homebrew/opt/ruby@3.3/bin:$PATH"
export LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8
exec bundle exec fastlane "$@"
