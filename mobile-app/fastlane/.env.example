# Copy to fastlane/.env (gitignored) and fill in. Key files live OUTSIDE git.
# Real values are documented in credentials/CREDENTIALS.md.

# App Store Connect API key
FASTLANE_APP_STORE_CONNECT_KEY_ID=XXXXXXXXXX
FASTLANE_APP_STORE_CONNECT_ISSUER_ID=00000000-0000-0000-0000-000000000000
FASTLANE_APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# Apple signing / identifiers
FASTLANE_APPLE_TEAM_ID=XXXXXXXXXX
FASTLANE_IOS_APP_IDENTIFIER=com.zaparc.app
FASTLANE_IOS_SCHEME=ZapArc

# Google Play service account (account-level publisher)
FASTLANE_PLAY_JSON_KEY_PATH=/absolute/path/to/play-service-account.json
FASTLANE_ANDROID_PACKAGE_NAME=com.zaparc.app

# Optional
# FASTLANE_RELEASE_NOTES_PATH=fastlane/release-notes.txt
# FASTLANE_PLAY_RELEASE_STATUS=completed   # or "draft"
